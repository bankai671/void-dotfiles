#!/bin/sh

tiramisu -j | while read -r event; do
    summary=$(echo "$event" | jq -r '.summary')
    body=$(echo "$event" | jq -r '.body')

    [ "$summary" = "null" ] && summary=""
    [ "$body" = "null" ] && body=""

    if [ -n "$body" ]; then
        herbe "$summary: $body" &
    else
        herbe "$summary" &
    fi
done
